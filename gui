-- Executor-ready Combat UI Library (Module)
-- Works with Synapse, KRNL, ScriptWare, etc.
-- Features: executor-safe parenting, syn.protect_gui, auto-resize, tab system, toggles, dropdowns, buttons

local UILib = {}
UILib.__index = UILib

-- Services
local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

-- Theme colors (Spring theme by default)
local colors = {
    Primary = Color3.fromRGB(120, 210, 120),
    Secondary = Color3.fromRGB(85, 170, 85),
    Accent = Color3.fromRGB(255, 105, 180),
    Background = Color3.fromRGB(30, 30, 40),
    Card = Color3.fromRGB(40, 40, 50),
    Text = Color3.fromRGB(240, 240, 240),
    Stroke = Color3.fromRGB(60, 60, 70)
}

-- Utility: safe call
local function safe_call(f, ...)
    local ok, res = pcall(f, ...)
    if not ok then
        warn("[UILib] error:", res)
    end
    return ok, res
end

-- Utility: choose best parent for GUI (executor-aware)
local function choose_parent()
    -- Prefer gethui (KRNL/Synapse), then PlayerGui, then CoreGui
    if type(gethui) == "function" then
        local ok, res = pcall(gethui)
        if ok and res then return res end
    end

    -- Some executors expose 'get_hidden_gui' or similar
    if type(get_hidden_gui) == "function" then
        local ok, res = pcall(get_hidden_gui)
        if ok and res then return res end
    end

    -- PlayerGui if available
    local pl = Players.LocalPlayer
    if pl then
        local ok, pg = pcall(function() return pl:WaitForChild("PlayerGui", 5) end)
        if ok and pg then return pg end
    end

    -- Fallback to CoreGui
    local core = game:GetService("CoreGui")
    return core
end

-- Internal: protect GUI for synapse if available
local function protect_gui_if_possible(screenGui)
    if type(syn) == "table" and type(syn.protect_gui) == "function" then
        safe_call(function() syn.protect_gui(screenGui) end)
    end
    -- Other executors might expose protect functions; add checks as needed
end


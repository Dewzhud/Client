-- Dragging implementation (robust)
function UILib:MakeDraggable(frame)
    local dragging = false
    local dragStart = Vector2.new()
    local startPos = Vector2.new()

    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            local p = self.MainFrame.Position
            startPos = Vector2.new(p.X.Offset, p.Y.Offset)
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    frame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            -- noop; handled in global InputChanged
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            local newX = startPos.X + delta.X
            local newY = startPos.Y + delta.Y
            -- keep within screen bounds (basic clamp)
            local screenX = math.clamp(newX, -1000, 1000)
            local screenY = math.clamp(newY, -1000, 1000)
            self.MainFrame.Position = UDim2.new(self.MainFrame.Position.X.Scale, screenX, self.MainFrame.Position.Y.Scale, screenY)
        end
    end)
end

-- Create a tab
function UILib:CreateTab(name)
    if not name then return end
    if self.Tabs[name] then return self.Tabs[name] end

    local tab = {}

    -- Button
    tab.Button = Instance.new("TextButton")
    tab.Button.Name = tostring(name) .. "Tab"
    tab.Button.AutoButtonColor = false
    tab.Button.BackgroundColor3 = colors.Card
    tab.Button.BorderSizePixel = 0
    tab.Button.Text = tostring(name)
    tab.Button.TextColor3 = colors.Text
    tab.Button.Font = Enum.Font.Gotham
    tab.Button.TextSize = 14
    tab.Button.Size = UDim2.new(0, 84, 1, 0)
    tab.Button.Parent = self.TabContainer

    -- Container
    tab.Container = Instance.new("Frame")
    tab.Container.Name = tostring(name) .. "Container"
    tab.Container.Size = UDim2.new(1, 0, 0, 0)
    tab.Container.BackgroundTransparency = 1
    tab.Container.Visible = false
    tab.Container.Parent = self.ContentFrame

    local containerLayout = Instance.new("UIListLayout")
    containerLayout.Padding = UDim.new(0, 10)
    containerLayout.SortOrder = Enum.SortOrder.LayoutOrder
    containerLayout.Parent = tab.Container

    -- store
    self.Tabs[name] = tab
    table.insert(self.TabOrder, name)

    -- click
    tab.Button.MouseButton1Click:Connect(function()
        self:SwitchTab(name)
    end)

    -- if first tab, switch
    if #self.TabOrder == 1 then
        self:SwitchTab(name)
    end

    return tab
end

-- Switch between tabs
function UILib:SwitchTab(tabName)
    if not tabName or not self.Tabs[tabName] then return end
    if self.CurrentTab and self.Tabs[self.CurrentTab] then
        self.Tabs[self.CurrentTab].Button.BackgroundColor3 = colors.Card
        self.Tabs[self.CurrentTab].Container.Visible = false
    end

    self.CurrentTab = tabName
    local t = self.Tabs[tabName]
    t.Button.BackgroundColor3 = colors.Primary
    t.Container.Visible = true
end

-- Create category within a tab
function UILib:CreateCategory(tabName, categoryName)
    local tab = self.Tabs[tabName]
    if not tab then return end

    local category = {}

    category.Frame = Instance.new("Frame")
    category.Frame.Name = tostring(categoryName)
    category.Frame.Size = UDim2.new(1, -20, 0, 40)
    category.Frame.BackgroundColor3 = colors.Card
    category.Frame.BorderSizePixel = 0
    category.Frame.LayoutOrder = #tab.Container:GetChildren() + 1
    category.Frame.Parent = tab.Container

    category.Label = Instance.new("TextLabel")
    category.Label.Name = "Label"
    category.Label.Size = UDim2.new(1, -20, 0, 30)
    category.Label.Position = UDim2.new(0, 10, 0, 6)
    category.Label.BackgroundTransparency = 1
    category.Label.Text = tostring(categoryName)
    category.Label.TextColor3 = colors.Primary
    category.Label.Font = Enum.Font.GothamBold
    category.Label.TextSize = 16
    category.Label.TextXAlignment = Enum.TextXAlignment.Left
    category.Label.Parent = category.Frame

    -- Options Frame (holds toggles/buttons/etc)
    category.Options = Instance.new("Frame")
    category.Options.Name = "Options"
    category.Options.Size = UDim2.new(1, -20, 0, 0)
    category.Options.Position = UDim2.new(0, 10, 0, 40)
    category.Options.BackgroundTransparency = 1
    category.Options.Parent = category.Frame

    local optionsLayout = Instance.new("UIListLayout")
    optionsLayout.Padding = UDim.new(0, 6)
    optionsLayout.SortOrder = Enum.SortOrder.LayoutOrder
    optionsLayout.Parent = category.Options

    -- Auto update sizes when children change
    optionsLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        local h = optionsLayout.AbsoluteContentSize.Y
        category.Options.Size = UDim2.new(1, -20, 0, h)
        category.Frame.Size = UDim2.new(1, -20, 0, 40 + h + 12)
    end)

    return category
end

-- Create toggle
function UILib:CreateToggle(category, optionName, defaultValue, callback)
    if not category or not category.Options then return end
    local toggle = {}
    toggle.State = defaultValue and true or false

    toggle.Frame = Instance.new("Frame")
    toggle.Frame.Name = tostring(optionName)
    toggle.Frame.Size = UDim2.new(1, 0, 0, 30)
    toggle.Frame.BackgroundTransparency = 1
    toggle.Frame.Parent = category.Options

    toggle.Label = Instance.new("TextLabel")
    toggle.Label.Name = "Label"
    toggle.Label.Size = UDim2.new(1, -80, 1, 0)
    toggle.Label.Position = UDim2.new(0, 6, 0, 0)
    toggle.Label.BackgroundTransparency = 1
    toggle.Label.Text = tostring(optionName)
    toggle.Label.TextColor3 = colors.Text
    toggle.Label.Font = Enum.Font.Gotham
    toggle.Label.TextSize = 14
    toggle.Label.TextXAlignment = Enum.TextXAlignment.Left
    toggle.Label.Parent = toggle.Frame

    toggle.Button = Instance.new("TextButton")
    toggle.Button.Name = "ToggleButton"
    toggle.Button.Size = UDim2.new(0, 64, 0, 24)
    toggle.Button.Position = UDim2.new(1, -70, 0.5, -12)
    toggle.Button.BackgroundColor3 = toggle.State and colors.Primary or Color3.fromRGB(60,60,70)
    toggle.Button.BorderSizePixel = 0
    toggle.Button.Text = toggle.State and "ON" or "OFF"
    toggle.Button.TextColor3 = colors.Text
    toggle.Button.Font = Enum.Font.Gotham
    toggle.Button.TextSize = 12
    toggle.Button.Parent = toggle.Frame

    toggle.Button.MouseButton1Click:Connect(function()
        toggle.State = not toggle.State
        toggle.Button.BackgroundColor3 = toggle.State and colors.Primary or Color3.fromRGB(60,60,70)
        toggle.Button.Text = toggle.State and "ON" or "OFF"
        if typeof(callback) == "function" then
            task.spawn(callback, toggle.State)
        end
    end)

    return toggle
end

-- Create button
function UILib:CreateButton(category, buttonName, callback)
    if not category or not category.Options then return end
    local btn = Instance.new("TextButton")
    btn.Name = tostring(buttonName)
    btn.Size = UDim2.new(1, 0, 0, 36)
    btn.BackgroundColor3 = colors.Secondary
    btn.BorderSizePixel = 0
    btn.Text = tostring(buttonName)
    btn.TextColor3 = colors.Text
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 14
    btn.Parent = category.Options

    btn.MouseButton1Click:Connect(function()
        if typeof(callback) == "function" then
            task.spawn(callback)
        end
    end)

    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.12), {BackgroundColor3 = colors.Primary}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.12), {BackgroundColor3 = colors.Secondary}):Play()
    end)

    return btn
end

-- Create dropdown
function UILib:CreateDropdown(category, dropdownName, options, defaultIndex, callback)
    if not category or not category.Options then return end
    local dropdown = {}
    dropdown.Options = options or {}
    dropdown.SelectedIndex = math.clamp(defaultIndex or 1, 1, #dropdown.Options)
    dropdown.Open = false

    dropdown.Frame = Instance.new("Frame")
    dropdown.Frame.Size = UDim2.new(1, 0, 0, 30)
    dropdown.Frame.BackgroundTransparency = 1
    dropdown.Frame.Parent = category.Options

    dropdown.Button = Instance.new("TextButton")
    dropdown.Button.Size = UDim2.new(1, 0, 1, 0)
    dropdown.Button.BackgroundColor3 = colors.Secondary
    dropdown.Button.BorderSizePixel = 0
    dropdown.Button.Text = tostring(dropdownName) .. ": " .. (dropdown.Options[dropdown.SelectedIndex] or "Select")
    dropdown.Button.TextColor3 = colors.Text
    dropdown.Button.Font = Enum.Font.Gotham
    dropdown.Button.TextSize = 14
    dropdown.Button.TextXAlignment = Enum.TextXAlignment.Left
    dropdown.Button.Parent = dropdown.Frame

    dropdown.OptionsFrame = Instance.new("Frame")
    dropdown.OptionsFrame.Name = "OptionsFrame"
    dropdown.OptionsFrame.Size = UDim2.new(1, 0, 0, 0)
    dropdown.OptionsFrame.Position = UDim2.new(0, 0, 1, 4)
    dropdown.OptionsFrame.BackgroundColor3 = colors.Card
    dropdown.OptionsFrame.BorderSizePixel = 0
    dropdown.OptionsFrame.ClipsDescendants = true
    dropdown.OptionsFrame.Visible = false
    dropdown.OptionsFrame.Parent = dropdown.Frame

    local layout = Instance.new("UIListLayout")
    layout.Padding = UDim.new(0, 2)
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Parent = dropdown.OptionsFrame

    for i, opt in ipairs(dropdown.Options) do
        local b = Instance.new("TextButton")
        b.Name = tostring(opt)
        b.Size = UDim2.new(1, 0, 0, 28)
        b.BackgroundColor3 = colors.Background
        b.BorderSizePixel = 0
        b.Text = tostring(opt)
        b.TextColor3 = colors.Text
        b.Font = Enum.Font.Gotham
        b.TextSize = 12
        b.LayoutOrder = i
        b.Parent = dropdown.OptionsFrame

        b.MouseButton1Click:Connect(function()
            dropdown.SelectedIndex = i
            dropdown.Button.Text = tostring(dropdownName) .. ": " .. tostring(opt)
            dropdown.Open = false
            dropdown.OptionsFrame.Visible = false
            dropdown.OptionsFrame.Size = UDim2.new(1,0,0,0)
            if typeof(callback) == "function" then
                task.spawn(callback, opt, i)
            end
        end)
    end

    dropdown.Button.MouseButton1Click:Connect(function()
        dropdown.Open = not dropdown.Open
        dropdown.OptionsFrame.Visible = dropdown.Open
        if dropdown.Open then
            local optionCount = #dropdown.Options
            local h = math.clamp(optionCount * 30, 0, 200)
            dropdown.OptionsFrame.Size = UDim2.new(1, 0, 0, h)
        else
            dropdown.OptionsFrame.Size = UDim2.new(1, 0, 0, 0)
        end
    end)

    return dropdown
end

-- Initialize the UI and parent to proper place (executor-safe)
function UILib:Init()
    -- Parent selection
    local parent = choose_parent()
    -- protect GUI if syn available
    protect_gui_if_possible(self.ScreenGui)
    -- Parent safely
    safe_call(function()
        self.ScreenGui.Parent = parent
    end)

    -- For compatibility: if ScreenGui ended up in CoreGui and blocked, try PlayerGui as fallback
    if not self.ScreenGui.Parent then
        local pl = Players.LocalPlayer
        if pl and pl:FindFirstChild("PlayerGui") then
            safe_call(function() self.ScreenGui.Parent = pl.PlayerGui end)
        end
    end

    print("[UILib] Initialized and parented to:", tostring(self.ScreenGui.Parent) )
    return self
end

-- Toggle visibility
function UILib:Toggle()
    self.ScreenGui.Enabled = not self.ScreenGui.Enabled
end

-- Destroy
function UILib:Destroy()
    safe_call(function() self.ScreenGui:Destroy() end)
end

